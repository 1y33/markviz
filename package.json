{
  "name": "markviz",
  "version": "0.1.0",
  "description": "Fast, beautiful markdown viewer/editor that runs in your browser, launched from the terminal.",
  "type": "module",
  "bin": {
    "markviz": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "web/dist",
    "README.md"
  ],
  "scripts": {
    "dev:web": "vite --config web/vite.config.ts",
    "build:web": "vite build --config web/vite.config.ts",
    "build:server": "esbuild src/cli/index.ts src/server/index.ts --bundle --platform=node --target=node20 --format=esm --packages=external --outdir=dist --out-extension:.js=.js",
    "build": "npm run build:web && npm run build:server && npm run build:skills && node -e \"import('fs').then(fs=>fs.chmodSync('dist/cli/index.js',0o755))\"",
    "build:skills": "node -e \"const fs=require('fs');const path=require('path');function cp(src,dst){fs.mkdirSync(path.dirname(dst),{recursive:true});if(fs.statSync(src).isDirectory()){fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src))cp(path.join(src,f),path.join(dst,f));}else{fs.copyFileSync(src,dst);}}fs.rmSync('dist/skills',{recursive:true,force:true});cp('.claude/skills','dist/skills');\"",
    "start": "node dist/cli.js",
    "dev": "npm run build:server && MARKVIZ_DEV=1 node dist/cli.js"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "commander": "^12.1.0",
    "fastify": "^5.0.0",
    "mermaid": "^11.15.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.24.0",
    "katex": "^0.16.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "shiki": "^1.22.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "markdown",
    "viewer",
    "cli",
    "katex",
    "shiki",
    "notes"
  ],
  "license": "MIT"
}
